# ─── MySQL ───
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=rxuser
DB_PASSWORD=changeme
DB_NAME=securerx

# ─── JWT ───
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXP_MIN=60

# ─── CA interna (material persistente) ───
CA_DIR=ca

# ─── CORS (whitelist separada por comas) ───
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Admin bootstrap (idempotente — se crea SOLO si no hay admin activo) ───
# En contenedores, setea ADMIN_PASSWORD y el admin se genera al arranque.
# El bundle PEM privado se imprime UNA sola vez en los logs — guárdalo.
ADMIN_USERNAME=admin
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@securerx.app
ADMIN_PASSWORD=
